# Same Supabase project the game server uses
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_KEY=service-role-key

# Slack app (https://api.slack.com/apps):
#  - OAuth & Permissions -> Redirect URLs: <BASE_URL>/api/auth/callback
#  - Bot Token Scopes: chat:write, im:write
#  - Install to workspace, copy the Bot User OAuth Token below
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_BOT_TOKEN=xoxb-...

# Comma-separated Slack member IDs allowed into the dashboard (e.g. U0123ABC,U0456DEF)
ADMIN_SLACK_IDS=

# Long random string for signing session cookies
SESSION_SECRET=

# Where this dashboard runs (used for the OAuth redirect)
BASE_URL=http://localhost:4900
